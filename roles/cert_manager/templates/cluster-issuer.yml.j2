# This file managed by Ansible
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt
spec:
  acme:
    email: {{ cert_manager_email }}
    server: "{{ 'https://acme-staging-v02.api.letsencrypt.org/directory' if cert_manager_staging else 'https://acme-v02.api.letsencrypt.org/directory' }}"
    privateKeySecretRef:
      name: letsencrypt-account-key
    solvers:
      - http01:
          ingress:
            class: traefik
